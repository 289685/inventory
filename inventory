void fail(const string& prompt, int& value) {
	while (true) {
		cout << prompt;
		cin >> value;
		if (cin.fail()) {
			cin.clear();
			cin.ignore(1000, '\n');
			cout << "Invalid input. Try again.\n";
		} else {
			break;
		}
	}
}

